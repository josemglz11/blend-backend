# BLEND Backend Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/blend_db"

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Your frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# Get these from your Stripe dashboard at dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── COPACKER ─────────────────────────────────────────────────────────────────
# Your co-packer's webhook endpoint for receiving pick-pack orders.
# Leave blank during development. Orders will be saved to the DB only.
COPACKER_WEBHOOK_URL=
COPACKER_API_KEY=

# ─── EMAIL (Resend) ───────────────────────────────────────────────────────────
# Get your API key at resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=orders@yourdomain.com
